<?xml version="1.0" encoding="utf-8"?>
<!--
  widget_pomo.xml — 番茄钟快捷启动桌面小部件
  一键点击直接开始番茄钟倒计时
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pomo_focus"
    android:clickable="true"
    android:focusable="true"
    android:padding="@dimen/widget_padding">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="@string/widget_launch_pomodoro"
            android:src="@drawable/ic_play"
            android:alpha="0.9" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/widget_launch_pomodoro"
            android:textColor="@android:color/white"
            android:textSize="@dimen/widget_font_size"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
